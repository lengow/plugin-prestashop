{% extends base_layout %}

{% block lengow_header %}
    {% include '@Modules/lengow/views/templates/admin/twig/header.html.twig' %}
{% endblock %}

{% block lengow_content %}
<div class="cms-global" id="lengow_feed_wrapper">
    <div class="lgw-container">
        {% if debugMode %}
            <div id="lgw-debug" class="adminlengowfeed {% if multiShop %}multi-shop{% endif %}">
                {{ locale.t('menu.debug_active') }}
            </div>
        {% endif %}
        {% for shop in shopCollection %}
            <div class="filter-column">
                <div class="sticky-icon" data-shop-id="{{ shop['shop'].id }}" id="sticky-icon-{{ shop['shop'].id }}">
                    <a title="{{ locale.t('product.screen.filter_exported') }}">
                        <i style="font-size: 20px;color: #555" class="fa fa-filter"></i>
                    </a>
                </div>
            </div>
            <div class="lgw-box" id="block_{{ shop['shop'].id }}">
                <a href="{{ shop['link'] }}&stream=1&update_export_date=0"
                   class="lengow_export_feed lengow_link_tooltip"
                   data-original-title="{{ locale.t('product.screen.button_download') }}"
                   target="_blank"><i class="fa fa-download"></i></a>
                <h2 class="text-center catalog-title lengow_link_tooltip"
                    data-original-title="{{ shop['shop'].name }} ({{ shop['shop'].id }})
                    {{ shop['shop'].domain }}">
                    {{ shop['shop'].name }}
                </h2>
                <div class="text-center">
                    <div class="margin-standard text-center">
                        <p class="products-exported">
                            <span class="lengow_exported stats-big-value">{{ shop['total_export_product'] }}</span>
                            {{ locale.t('product.screen.nb_exported') }}
                        </p>
                        <p class="products-available small light">
                            <span class="lengow_total stats-big-value">{{ shop['total_product'] }}</span>
                            {{ locale.t('product.screen.nb_available') }}
                        </p>
                    </div>
                    <hr>
                    <div class="sticky-switch-{{ shop['shop'].id }} sticky-switch" data-shop-id="{{ shop['shop'].id }}" id="sticky-switch-{{ shop['shop'].id }}">
                        <div class="switch-row variation-row">
                            <div class="lgw-switch switch-variation {% if shop['option_selected__variation'] == 1 %} checked{% endif %}">
                                <label>
                                    <div><span></span>
                                        <input
                                                type="checkbox"
                                                data-size="mini"
                                                data-on-text="{{ locale.t('product.screen.button_yes') }}"
                                                data-off-text="{{ locale.t('product.screen.button_no') }}"
                                                name="lengow_export_variation"
                                                class="lengow_switch_option option-variation-{{ shop['shop'].id }}"
                                                data-href="{{ lengow_link.getAbsoluteAdminLink('AdminLengowFeed') }}"
                                                data-action="change_option_selected__variation"
                                                data-id_shop="{{ shop['shop'].id }}"
                                                value="1" {% if shop['option_selected__variation'] == 1 %} checked="checked"{% endif %}
                                        >
                                    </div> {{ locale.t('product.screen.include_variation_product') }}
                                </label>
                            </div>
                        </div>
                        <br>
                        <div class="switch-row">
                            <div class="lgw-switch switch-out-of-stock {% if shop['option_selected__out_of_stock'] == 1 %} checked{% endif %}">
                                <label>
                                    <div><span></span>
                                        <input
                                                type="checkbox"
                                                data-size="mini"
                                                data-on-text="{{ locale.t('product.screen.button_yes') }}"
                                                data-off-text="{{ locale.t('product.screen.button_no') }}"
                                                name="lengow_export_out_of_stock"
                                                class="lengow_switch_option option-out-of-stock-{{ shop['shop'].id }}"
                                                data-href="{{ lengow_link.getAbsoluteAdminLink('AdminLengowFeed') }}"
                                                data-action="change_option_selected__out_of_stock"
                                                data-id_shop="{{ shop['shop'].id }}"
                                                value="1" {% if shop['option_selected__out_of_stock'] == 1 %} checked="checked"{% endif %}
                                        >
                                    </div> {{ locale.t('product.screen.include_out_of_stock_product') }}
                                </label>
                            </div>
                        </div>
                        <br>
                        <div class="switch-row">
                            <div class="lgw-switch switch-inactive {% if shop['option_selected__inactive'] == 1 %} checked{% endif %}">
                                <label>
                                    <div><span></span>
                                        <input
                                                type="checkbox"
                                                data-size="mini"
                                                data-on-text="{{ locale.t('product.screen.button_yes') }}"
                                                data-off-text="{{ locale.t('product.screen.button_no') }}"
                                                name="lengow_export_inactive"
                                                class="lengow_switch_option option-inactive-{{ shop['shop'].id }}"
                                                data-href="{{ lengow_link.getAbsoluteAdminLink('AdminLengowFeed') }}"
                                                data-action="change_option_selected__inactive"
                                                data-id_shop="{{ shop['shop'].id }}"
                                                value="1" {% if shop['option_selected__inactive'] == 1 %} checked="checked"{% endif %}
                                        >
                                    </div> {{ locale.t('product.screen.include_inactive_product') }}
                                </label>
                            </div>
                        </div>
                        <br>
                        <div class="switch-row">
                            <div class="lgw-switch switch-selection {% if shop['option_selected__selection'] == 1 %} checked{% endif %}">
                                <label>
                                    <div><span></span>
                                        <input
                                                type="checkbox"
                                                data-size="mini"
                                                data-on-text="{{ locale.t('product.screen.button_yes') }}"
                                                data-off-text="{{ locale.t('product.screen.button_no') }}"
                                                name="lengow_export_selection"
                                                class="lengow_switch_option option-selection-{{ shop['shop'].id }}"
                                                data-href="{{ lengow_link.getAbsoluteAdminLink('AdminLengowFeed') }}"
                                                data-action="change_option_selected__selection"
                                                data-id_shop="{{ shop['shop'].id }}"
                                                value="1" {% if shop['option_selected__selection'] == 1 %} checked="checked"{% endif %}
                                        >
                                    </div> {{ locale.t('product.screen.include_specific_product') }}
                                </label>
                            </div>
                            <i class="fa fa-info-circle lengow_link_tooltip"
                               title="{{ locale.t('product.screen.include_specific_product_support') }}"></i>
                        </div>
                    </div>
                </div>
                <div class="lengow_feed_block_footer">
                    <div class="lengow_feed_block_footer_content" style="{% if not shop['option_selected__selection'] %}display:none;{% endif %}">
                        {{ shop['list']|raw }}
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
</div>
<script type="text/javascript" src="{{ lengowPathUri }}views/js/lengow/feed.js"></script>
{% endblock %}

{% block lengow_footer %}
    {% include '@Modules/lengow/views/templates/admin/twig/footer.html.twig' %}
{% endblock %}
